<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.projectrplbo.controller.LupaPasswordController"
           styleClass="page-bg"
           stylesheets="@css/styles.css">
    <VBox alignment="CENTER" StackPane.alignment="CENTER">
        <VBox styleClass="card-white" maxWidth="560" minWidth="480" spacing="0">
            <padding><Insets top="52" bottom="52" left="60" right="60"/></padding>

            <Label text="Lupa Password" styleClass="card-title"/>
            <Label text="Masukkan Email Anda untuk reset Password"
                   styleClass="card-subtitle"/>
            <Region prefHeight="28"/>

            <VBox spacing="6">
                <Label text="Email" styleClass="form-label"/>
                <TextField fx:id="tfEmail" promptText="Masukkan email Anda"
                           styleClass="form-input" maxWidth="Infinity"/>
            </VBox>
            <Region prefHeight="16"/>

            <VBox fx:id="boxNewPassword" spacing="16" visible="false" managed="false">
                <VBox spacing="6">
                    <Label text="Password Baru" styleClass="form-label"/>
                    <PasswordField fx:id="pfPasswordBaru" promptText="Minimal 6 karakter"
                                   styleClass="form-input" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Konfirmasi Password" styleClass="form-label"/>
                    <PasswordField fx:id="pfKonfirmasiPassword" promptText="Ulangi password baru"
                                   styleClass="form-input" maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <Label fx:id="lblStatus" styleClass="info-label" wrapText="true"
                   visible="false" managed="false" maxWidth="Infinity"/>
            <Region prefHeight="8"/>

            <Button text="Kirim" onAction="#handleKirim"
                    styleClass="btn-primary" maxWidth="Infinity" prefHeight="46"/>
            <Region prefHeight="12"/>

            <Button text="Kembali Ke Halaman Login" onAction="#handleKembaliLogin"
                    styleClass="btn-secondary" maxWidth="Infinity" prefHeight="46"/>
            <Region prefHeight="20"/>

            <HBox alignment="CENTER">
                <Label text="QuickBite" styleClass="brand-link-static"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
