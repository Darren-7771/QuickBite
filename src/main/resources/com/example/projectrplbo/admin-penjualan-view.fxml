<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.projectrplbo.controller.AdminPenjualanController"
           stylesheets="@css/styles.css">

    <BorderPane fx:id="mainPane" prefWidth="1100" prefHeight="700"
                styleClass="admin-root">

        <left>
            <VBox styleClass="admin-sidebar" prefWidth="220" minWidth="200">
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="admin-sidebar-brand">
                    <padding><Insets top="24" bottom="24" left="20" right="20"/></padding>
                    <Label text="🍴" styleClass="admin-brand-icon"/>
                    <Label text="QuickBite" styleClass="admin-brand-name"/>
                </HBox>

                <VBox styleClass="admin-nav" VBox.vgrow="ALWAYS" spacing="4">
                    <padding><Insets top="20" left="12" right="12" bottom="12"/></padding>

                    <HBox styleClass="admin-nav-item" alignment="CENTER_LEFT" spacing="12"
                          onMouseClicked="#handleNavDashboard">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="⊞" styleClass="admin-nav-icon"/>
                        <Label text="Dashboard" styleClass="admin-nav-label"/>
                    </HBox>

                    <HBox styleClass="admin-nav-item" alignment="CENTER_LEFT" spacing="12"
                          onMouseClicked="#handleNavProduk">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="⬡" styleClass="admin-nav-icon"/>
                        <Label text="Manajemen Produk" styleClass="admin-nav-label"/>
                    </HBox>

                    <HBox styleClass="admin-nav-item-active" alignment="CENTER_LEFT" spacing="12">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="↗" styleClass="admin-nav-icon"/>
                        <Label text="Manajemen Penjualan" styleClass="admin-nav-label-active"/>
                    </HBox>

                    <HBox styleClass="admin-nav-item" alignment="CENTER_LEFT" spacing="12"
                          onMouseClicked="#handleNavJamOp">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="⏱" styleClass="admin-nav-icon"/>
                        <Label text="Manajemen Jam Operasional" styleClass="admin-nav-label" wrapText="true"/>
                    </HBox>

                    <HBox styleClass="admin-nav-item" alignment="CENTER_LEFT" spacing="12"
                          onMouseClicked="#handleNavAkun">
                        <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                        <Label text="👤" styleClass="admin-nav-icon"/>
                        <Label text="Manajemen Akun" styleClass="admin-nav-label"/>
                    </HBox>
                </VBox>

                <VBox styleClass="admin-sidebar-footer">
                    <padding><Insets top="16" bottom="16" left="16" right="16"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <StackPane styleClass="admin-avatar">
                            <Label text="👤" styleClass="admin-avatar-icon"/>
                        </StackPane>
                        <VBox>
                            <Label text="Admin" styleClass="admin-profile-role"/>
                            <Label fx:id="lblNamaAdmin" text="Administrator" styleClass="admin-profile-name"/>
                        </VBox>
                    </HBox>
                    <Region prefHeight="12"/>
                    <Button text="⬅  Keluar" onAction="#handleKeluar"
                            styleClass="admin-btn-keluar" maxWidth="Infinity"/>
                </VBox>
            </VBox>
        </left>

        <center>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="admin-content-scroll">
                <VBox styleClass="admin-content">

                    <HBox alignment="CENTER_LEFT" styleClass="admin-content-header">
                        <padding><Insets top="28" bottom="20" left="32" right="32"/></padding>
                        <Label text="Manajemen Penjualan" styleClass="admin-page-title"/>
                    </HBox>

                    <HBox spacing="20" styleClass="admin-stat-row">
                        <padding><Insets left="32" right="32" bottom="24"/></padding>

                        <VBox styleClass="admin-penjualan-stat-card" HBox.hgrow="ALWAYS" spacing="4">
                            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <StackPane styleClass="admin-penjualan-stat-icon-box">
                                    <Label text="💳" styleClass="admin-penjualan-stat-icon"/>
                                </StackPane>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPersenPendapatan" text="+12.5%" styleClass="admin-penjualan-badge-green"/>
                            </HBox>
                            <Region prefHeight="4"/>
                            <Label text="Total Pendapatan Hari Ini" styleClass="admin-stat-label"/>
                            <Label fx:id="lblTotalPendapatan" text="Rp 0" styleClass="admin-stat-value"/>
                            <Label fx:id="lblUpdateTerakhir" text="Update terakhir: --:--" styleClass="admin-penjualan-stat-sub"/>
                        </VBox>

                        <VBox styleClass="admin-penjualan-stat-card" HBox.hgrow="ALWAYS" spacing="4">
                            <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <StackPane styleClass="admin-penjualan-stat-icon-box">
                                    <Label text="🔒" styleClass="admin-penjualan-stat-icon"/>
                                </StackPane>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPersenPesanan" text="+8.2%" styleClass="admin-penjualan-badge-green"/>
                            </HBox>
                            <Region prefHeight="4"/>
                            <Label text="Jumlah Pesanan Sukses" styleClass="admin-stat-label"/>
                            <Label fx:id="lblJumlahPesananSukses" text="0" styleClass="admin-stat-value"/>
                            <Label fx:id="lblDariTotal" text="Dari 0 total pesanan" styleClass="admin-penjualan-stat-sub"/>
                        </VBox>
                    </HBox>

                    <VBox styleClass="admin-card" VBox.vgrow="ALWAYS">
                        <padding><Insets top="20" left="32" right="32" bottom="28"/></padding>

                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Riwayat Pemesanan" styleClass="admin-card-title"/>
                                <Label text="Menampilkan 10 pesanan terakhir"
                                       styleClass="admin-penjualan-table-sub"/>
                            </VBox>
                            <HBox styleClass="admin-search-box" alignment="CENTER_LEFT" spacing="8"
                                  minWidth="220" prefWidth="240">
                                <padding><Insets left="12" right="12"/></padding>
                                <Label text="🔍" styleClass="admin-search-icon"/>
                                <TextField fx:id="tfCariPesanan"
                                           promptText="Cari ID atau Nama..."
                                           styleClass="admin-search-inner"
                                           HBox.hgrow="ALWAYS"
                                           onKeyReleased="#handleCariPesanan"/>
                            </HBox>
                            <Button text="🖨  Cetak Laporan" onAction="#handleCetakLaporan"
                                    styleClass="admin-btn-primary"/>
                        </HBox>

                        <Region prefHeight="16"/>

                        <HBox styleClass="admin-table-header" spacing="0">
                            <padding><Insets top="10" bottom="10" left="16" right="16"/></padding>
                            <Label text="ID Pesanan"      styleClass="admin-th" minWidth="110"/>
                            <Label text="Nama Pelanggan"  styleClass="admin-th" minWidth="130" HBox.hgrow="ALWAYS"/>
                            <Label text="Waktu Transaksi" styleClass="admin-th" minWidth="120"/>
                            <Label text="Daftar Menu"     styleClass="admin-th" minWidth="210"/>
                            <Label text="Total Harga"     styleClass="admin-th" minWidth="100"/>
                            <Label text="Status"          styleClass="admin-th" minWidth="130" prefWidth="150" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                            <Label text="Aksi"            styleClass="admin-th" minWidth="180" prefWidth="190" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                        </HBox>

                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    hbarPolicy="NEVER" styleClass="admin-table-scroll">
                            <VBox fx:id="vboxPesananRows" styleClass="admin-table-body" spacing="0"/>
                        </ScrollPane>

                        <HBox alignment="CENTER_RIGHT" spacing="8">
                            <padding><Insets top="16" bottom="20"/></padding>
                            <Label fx:id="lblPagingInfo" text="" styleClass="admin-paging-info" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnPrev" text="Previous" onAction="#handlePrev" styleClass="admin-btn-paging"/>
                            <HBox fx:id="hboxPageNumbers" spacing="4" alignment="CENTER"/>
                            <Button fx:id="btnNext" text="Next"     onAction="#handleNext" styleClass="admin-btn-paging"/>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>

    <StackPane fx:id="modalOverlay" styleClass="admin-modal-overlay"
               visible="false" managed="false"
               alignment="CENTER">

        <VBox styleClass="admin-modal-card" maxWidth="360" spacing="0">

            <HBox alignment="TOP_LEFT">
                <padding><Insets top="12" left="14" right="14" bottom="0"/></padding>
                <Button text="✕" styleClass="admin-modal-close" onAction="#handleTutupModal"/>
            </HBox>

            <VBox styleClass="admin-modal-receipt" spacing="0">
                <padding><Insets top="4" left="32" right="32" bottom="28"/></padding>

                <Label text="Detail Transaksi" styleClass="admin-modal-receipt-title"/>
                <Region prefHeight="16"/>

                <HBox spacing="8">
                    <Label text="Id Transaksi"    styleClass="admin-modal-info-key" minWidth="130"/>
                    <Label fx:id="lblModalIdTransaksi" text="-" styleClass="admin-modal-info-val"/>
                </HBox>
                <HBox spacing="8">
                    <padding><Insets top="6"/></padding>
                    <Label text="Nama Pelanggan"  styleClass="admin-modal-info-key" minWidth="130"/>
                    <Label fx:id="lblModalNama"   text="-" styleClass="admin-modal-info-val-bold"/>
                </HBox>
                <HBox spacing="8">
                    <padding><Insets top="6"/></padding>
                    <Label text="Waktu Transaksi" styleClass="admin-modal-info-key" minWidth="130"/>
                    <Label fx:id="lblModalWaktu"  text="-" styleClass="admin-modal-info-val"/>
                </HBox>
                <HBox spacing="8">
                    <padding><Insets top="6"/></padding>
                    <Label text="Status Pesanan"  styleClass="admin-modal-info-key" minWidth="130"/>
                    <Label fx:id="lblModalStatus" text="-" styleClass="admin-modal-info-val"/>
                </HBox>

                <Label text="Detail Pembelian:" styleClass="admin-modal-info-key">
                    <padding><Insets top="10" bottom="8"/></padding>
                </Label>

                <VBox styleClass="admin-modal-receipt-box" spacing="0">
                    <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                    <VBox fx:id="vboxDetailItems" spacing="6"/>
                    <Region styleClass="admin-modal-divider" prefHeight="1" maxHeight="1"/>
                    <Region prefHeight="8"/>
                    <HBox spacing="8">
                        <Label text="Total Biaya"  styleClass="admin-modal-sum-key" minWidth="140" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblModalTotal" text="-" styleClass="admin-modal-sum-val"/>
                    </HBox>
                    <HBox spacing="8">
                        <padding><Insets top="4"/></padding>
                        <Label text="Uang Bayar"   styleClass="admin-modal-sum-key" minWidth="140" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblModalBayar" text="-" styleClass="admin-modal-sum-val"/>
                    </HBox>
                    <HBox spacing="8">
                        <padding><Insets top="4"/></padding>
                        <Label text="Uang Kembali" styleClass="admin-modal-sum-key" minWidth="140" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblModalKembali" text="Rp 0" styleClass="admin-modal-sum-val"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </StackPane>

    <StackPane fx:id="eksporOverlay" styleClass="admin-modal-overlay"
               visible="false" managed="false"
               alignment="CENTER">

        <VBox styleClass="admin-modal-card" maxWidth="340" spacing="0">

            <HBox alignment="TOP_LEFT">
                <padding><Insets top="12" left="14" right="14" bottom="0"/></padding>
                <Button text="✕" styleClass="admin-modal-close" onAction="#handleTutupEkspor"/>
            </HBox>

            <VBox spacing="16">
                <padding><Insets top="4" left="32" right="32" bottom="32"/></padding>

                <Label text="Ekspor Data Penjualan" styleClass="admin-modal-receipt-title"/>

                <Button text="⬇  Excel (.xlsx)" onAction="#handleEksporXlsx"
                        styleClass="admin-ekspor-btn" maxWidth="Infinity"/>

                <Button text="⬇  CSV (.csv)" onAction="#handleEksporCsv"
                        styleClass="admin-ekspor-btn" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </StackPane>

</StackPane>
