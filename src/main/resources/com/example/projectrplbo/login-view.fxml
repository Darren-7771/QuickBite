<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-page-bg" stylesheets="@css/styles.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.projectrplbo.controller.LoginController">

    <HBox styleClass="login-card" maxHeight="620" prefHeight="620">

        <VBox alignment="CENTER" prefWidth="380" spacing="24" styleClass="login-left">
            <padding><Insets bottom="60" left="40" right="40" top="60" /></padding>
            <Label styleClass="brand-icon" text="&#x1F374;" />
            <Label styleClass="brand-name" text="QuickBite" />
            <Label styleClass="brand-tagline" text="Sistem Chatbot Layanan Pelanggan untuk UMKM F&amp;B" textAlignment="CENTER" wrapText="true" />
            <VBox spacing="16" styleClass="feature-list">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="feature-icon" text="&#x2705;" />
                    <VBox>
                        <Label styleClass="feature-title" text="Pemesanan Cepat" />
                        <Label styleClass="feature-desc" text="Pesan makanan favorit Anda dengan mudah melalui chatbot" wrapText="true" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="feature-icon" text="&#x1F4CA;" />
                    <VBox>
                        <Label styleClass="feature-title" text="Dashboard Admin" />
                        <Label styleClass="feature-desc" text="Kelola menu, stok, dan penjualan dengan efisien" wrapText="true" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label styleClass="feature-icon" text="&#x1F550;" />
                    <VBox>
                        <Label styleClass="feature-title" text="Operasional Fleksibel" />
                        <Label styleClass="feature-desc" text="Atur jam operasional sesuai kebutuhan bisnis Anda" wrapText="true" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <VBox alignment="CENTER" prefWidth="580" spacing="0" styleClass="login-right">
            <padding><Insets bottom="60" left="70" right="70" top="60" /></padding>

            <Label styleClass="login-title" text="Selamat Datang Kembali" />
            <Label styleClass="login-subtitle" text="Masuk ke akun Anda untuk melanjutkan" />
            <Region prefHeight="24" />

            <Label styleClass="form-label-small" text="Masuk sebagai:" />
            <Region prefHeight="8" />
            <HBox prefHeight="44.0" prefWidth="413.0" spacing="0" styleClass="role-toggle-group">
                <ToggleButton fx:id="btnCustomer" prefHeight="36.0" prefWidth="229.0" selected="true" styleClass="role-btn-active" text="&#x1F464;  Customer" />
                <ToggleButton fx:id="btnAdmin" prefHeight="36.0" prefWidth="226.0" styleClass="role-btn" text="&#x1F464;  Admin" />
            </HBox>
            <Region prefHeight="24" />

            <Label styleClass="form-label" text="Username / Email" />
            <Region prefHeight="6" />
            <TextField fx:id="tfUsername" maxWidth="Infinity" promptText="Masukkan username atau email" styleClass="form-input" />
            <Region prefHeight="16" />

            <Label styleClass="form-label" text="Password" />
            <Region prefHeight="6" />
            <PasswordField fx:id="pfPassword" maxWidth="Infinity" promptText="Masukkan password" styleClass="form-input" />
            <Region prefHeight="8" />

            <HBox alignment="CENTER_RIGHT">
                <Hyperlink onAction="#handleLupaPassword" styleClass="hyperlink-small" text="Lupa Password?" />
            </HBox>
            <Region prefHeight="8" />

            <Label fx:id="lblError" managed="false" maxWidth="440" styleClass="error-label" visible="false" wrapText="true" />
            <Region prefHeight="4" />

            <Button maxWidth="Infinity" onAction="#handleMasuk" prefHeight="46" styleClass="btn-primary" text="Masuk" />
            <Region prefHeight="16" />

            <HBox alignment="CENTER" spacing="12">
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS" />
                <Label styleClass="divider-text" text="ATAU" />
                <Region styleClass="divider-line" HBox.hgrow="ALWAYS" />
            </HBox>
            <Region prefHeight="16" />

            <Label styleClass="form-label-small" text="Belum punya akun?" textAlignment="CENTER" />
            <Region prefHeight="8" />
            <Button maxWidth="Infinity" onAction="#handleDaftarAkunBaru" prefHeight="46" styleClass="btn-outline" text="&#x2795;  Daftar Akun Baru" />
        </VBox>
    </HBox>
</StackPane>
